# ============================================================
# Frontend PC-A — Configuración de API Gateway
# ============================================================

# CASO 1: Frontend y Backend en MISMO localhost
# VITE_API_GATEWAY_URL=http://localhost:9090

# CASO 2: Frontend en PC-A, Backend en PC-B (DIFERENTE RED)
# Reemplaza 192.168.1.100 con IP real de PC-B
# Usa: ipconfig en PC-B para obtener IPv4 Address
VITE_API_GATEWAY_URL=http://192.168.1.100:9090

# CASO 3: Producción (servidor remoto)
# VITE_API_GATEWAY_URL=http://54.196.217.78:9090
